<Window x:Class="BikesForRentWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BikesForRentWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Click="Data_btn_click" x:Name="btnData" Content="Nieuwe wachtwoord invoeren"  HorizontalAlignment="Left" Margin="40,20,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.075,3.223"/>
        <Button Click="Login_btn_click" x:Name="btnLogin" Content="Login"  HorizontalAlignment="Left" Margin="40,62,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.075,3.223"/>
        <Image Source="/Images/startImage.png" HorizontalAlignment="Left" Height="100" Margin="333,174,0,0" VerticalAlignment="Top" Width="100"/>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
