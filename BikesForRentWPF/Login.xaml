<Page Background="White"
      ShowsNavigationUI="False" x:Class="BikesForRentWPF.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BikesForRentWPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Database">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Label Content="Email" HorizontalAlignment="Center"/>
        <TextBox Width="120" x:Name="tbx_user_email" Height="21" TextAlignment="Center" Margin="20, 0, 20, 20"></TextBox>
        <Label Content="Wachtwoord" HorizontalAlignment="Center"/>
        <PasswordBox x:Name="pwb_user_wachtwoord" Width="120" Height="21" Margin="20, 0, 20, 20"/>
        <Button x:Name="btnInloggen" Content="Inloggen" Click="btnInloggen_Click" Margin="20"/>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" />


    </StackPanel>
</Page>
