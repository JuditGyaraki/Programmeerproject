<Page Background="White"
      ShowsNavigationUI="False" x:Class="BikesForRentWPF.AdminHomepage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BikesForRentWPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Database">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

        <Button x:Name="btn_Reservatie_Aanmaken" Content="Reservatie aanmaken" Click="btn_Reservatie_Aanmaken_Click" Width="120" Height="21" Margin="20, 0, 20, 20"/>
        <Button x:Name="btn_Reservatie_Beheren" Content="Reservatie beheren" Width="120" Height="21" Margin="20, 0, 20, 20"/>
        <Button x:Name="btn_Fietsen_Beheren" Content="Fietsen beheren" Width="120" Height="21" Margin="20, 0, 20, 20"/>
        <Button x:Name="btn_Uitloggen" Content="Uitloggen" Click="btn_Uitloggen_Click" Margin="20"/>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" />
    </StackPanel>
</Page>
