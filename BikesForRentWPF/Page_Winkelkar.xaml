<Page Background="White"
      x:Class="BikesForRentWPF.Page_Winkelkar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BikesForRentWPF"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="Page_Winkelkar">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LISTBOX -->
        <ListBox Grid.Row="0"
                 ItemsSource="{Binding SelectedBikes}"
                 d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListBox.ItemTemplate>
                <DataTemplate>

                    <Border BorderBrush="LightGray"
                            BorderThickness="1"
                            Margin="5"
                            Padding="5">

                        <StackPanel Orientation="Horizontal">

                            <Image Height="120"
                                   Width="120"
                                   Source="{Binding ImagePath}"/>

                            <StackPanel Margin="10,0,0,0">

                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           FontSize="16"/>

                                <TextBlock Text="{Binding Priceperday,
                                          StringFormat=Prijs per dag € : {0}}"
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="{Binding TotalPrice,
                                          StringFormat=Totaal € : {0}}"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding Days}"/>

                            </StackPanel>

                        </StackPanel>

                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <!-- BUTTONS -->
        <Grid Grid.Row="1" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LINKS -->
            <Button Grid.Column="0"
            Content="Annuleren"
            Width="120"
            Height="35"
            HorizontalAlignment="Left"
            Click="btn_Annuleren_Click"/>

            <!-- RECHTS -->
            <Button Grid.Column="1"
            Content="Reserveren"
            Width="120"
            Height="35"
            HorizontalAlignment="Right"
            Background="Green"
            Foreground="White"
            Click="btn_Reserveren_Click"/>

        </Grid>

    </Grid>

</Page>